{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Performance Canvas",
  "version": "0.1.0",
  "identifier": "ai.openflow.performancecanvas",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Performance Canvas",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"]
  }
}
